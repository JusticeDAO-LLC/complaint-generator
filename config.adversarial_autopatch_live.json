{
  "BACKENDS": [
    {
      "id": "hf-router",
      "type": "llm_router",
      "provider": "huggingface_router",
      "model": "Qwen/Qwen3-Coder-480B-A35B-Instruct",
      "base_url": "https://router.huggingface.co/v1",
      "max_tokens": 256,
      "temperature": 0.2
    }
  ],
  "MEDIATOR": {
    "backends": ["hf-router"]
  },
  "APPLICATION": {
    "type": "adversarial-autopatch",
    "demo_backend": false,
    "output_dir": "tmp/run_py_adversarial_autopatch_live",
    "target_file": "adversarial_harness/session.py",
    "num_sessions": 1,
    "max_turns": 2,
    "max_parallel": 1,
    "marker_prefix": "Launcher autopatch recommendation"
  },
  "LOG": {
    "level": "WARN"
  }
}