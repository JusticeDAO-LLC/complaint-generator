{
  "BACKENDS": [
    {
      "id": "llm-router",
      "type": "llm_router",
      "provider": "accelerate",
      "model": "gpt2",
      "max_tokens": 128
    }
  ],
  "MEDIATOR": {
    "backends": ["llm-router"]
  },
  "APPLICATION": {
    "type": "adversarial-autopatch",
    "demo_backend": false,
    "output_dir": "tmp/run_py_adversarial_autopatch_live_batch",
    "target_file": "adversarial_harness/session.py",
    "num_sessions": 4,
    "max_turns": 3,
    "max_parallel": 2,
    "marker_prefix": "Launcher autopatch recommendation"
  },
  "LOG": {
    "level": "WARN"
  }
}