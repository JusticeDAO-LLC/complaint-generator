{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Claim Support Regression",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "args": [
        "scripts/run_claim_support_review_regression.py"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "isBackground": false,
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Claim Support Regression (No Browser)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "args": [
        "scripts/run_claim_support_review_regression.py",
        "--browser",
        "off"
      ],
      "group": "test",
      "isBackground": false,
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Claim Support Regression (Require Browser)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "args": [
        "scripts/run_claim_support_review_regression.py",
        "--browser",
        "on"
      ],
      "group": "test",
      "isBackground": false,
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "HACC Grounding Regression",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
