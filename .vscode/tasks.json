      "command": "${workspaceFolder}/.venv/bin/python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "args": [
        "scripts/run_hacc_preset_matrix.py",
        "--presets",
        "core_hacc_policies,accommodation_focus",
        "--num-sessions",
        "1",
        "--hacc-count",
        "1",
        "--max-turns",
        "2",
        "--max-parallel",
        "1",
        "--output-dir",
        "../research_results/adversarial_runs/hacc_preset_matrix_smoke",
