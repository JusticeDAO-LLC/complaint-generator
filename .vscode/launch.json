{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Claim Support Regression",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_claim_support_review_regression.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Claim Support Regression (No Browser)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_claim_support_review_regression.py",
      "args": [
        "--browser",
        "off"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Claim Support Regression (Require Browser)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_claim_support_review_regression.py",
      "args": [
        "--browser",
        "on"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Claim Support Regression (Browser + Network)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_claim_support_review_regression.py",
      "args": [
        "--browser",
        "on",
        "--network",
        "on"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Package Install Smoke",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_package_install_smoke.py",
      "args": [
        "--json"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Standard Regression (Lean)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_standard_regression.py",
      "args": [
        "--slice",
        "lean"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Standard Regression (Review)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_standard_regression.py",
      "args": [
        "--slice",
        "review"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Standard Regression (Full)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_standard_regression.py",
      "args": [
        "--slice",
        "full"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "HACC Unit Regression",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_hacc_unit_regression.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "HACC Grounding Regression",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_hacc_grounding_regression.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "HACC Grounding Regression (No Smoke)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_hacc_grounding_regression.py",
      "args": [
        "--skip-smoke"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "HACC Grounded History",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/show_hacc_grounded_history.py",
      "args": [
        "--grounded-root",
        "output/hacc_grounded"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "HACC Adversarial Runner Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${workspaceFolder}/../HACC/tests/test_hacc_adversarial_runner.py",
        "-q"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/../HACC"
    },
    {
      "name": "Complaint Workspace CLI",
      "type": "debugpy",
      "request": "launch",
      "module": "complaint_generator.cli",
      "args": [
        "--help"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Complaint MCP Server",
      "type": "debugpy",
      "request": "launch",
      "module": "complaint_generator.mcp_server",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
