{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Claim Support Regression",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_claim_support_review_regression.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Claim Support Regression (No Browser)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_claim_support_review_regression.py",
      "args": [
        "--browser",
        "off"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Claim Support Regression (Require Browser)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_claim_support_review_regression.py",
      "args": [
        "--browser",
        "on"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}